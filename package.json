{
  "name": "tennis-availability",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install",
    "build": "cd server && npm install && npm run build && cd ../client && npm install && npx vite build",
    "start": "node server/dist/index.js",
    "dev:server": "cd server && npx tsx src/index.ts",
    "dev:client": "cd client && npx vite"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0",
    "node-html-parser": "^7.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "typescript": "^6.0.2"
  }
}
